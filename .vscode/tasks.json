{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "mvn: run",
			"type": "shell",
			"command": "cd socops && ./mvnw spring-boot:run",
			"options": {
				"env": {
					"JAVA_HOME": "C:\\Users\\PREGO\\dev\\tools\\OpenJDK21",
					"PATH": "C:\\Users\\PREGO\\dev\\tools\\OpenJDK21\\bin;${env:PATH}"
				}
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*Started.*Application.*",
					"endsPattern": "^.*Started.*Application.*in.*seconds.*"
				}
			},
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "mvn: build",
			"type": "shell",
			"command": "cd socops && ./mvnw clean package",
			"options": {
				"env": {
					"JAVA_HOME": "C:\\Users\\PREGO\\dev\\tools\\OpenJDK21",
					"PATH": "C:\\Users\\PREGO\\dev\\tools\\OpenJDK21\\bin;${env:PATH}"
				}
			},
			"group": "build"
		},
		{
			"label": "mvn: test",
			"type": "shell",
			"command": "cd socops && ./mvnw test",
			"options": {
				"env": {
					"JAVA_HOME": "C:\\Users\\PREGO\\dev\\tools\\OpenJDK21",
					"PATH": "C:\\Users\\PREGO\\dev\\tools\\OpenJDK21\\bin;${env:PATH}"
				}
			},
			"group": "test"
		}
	]
}